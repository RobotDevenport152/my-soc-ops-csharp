<div class="fixed inset-0 bg-cozy-brown/30 backdrop-blur-sm flex items-center justify-center p-4 z-50">
    <div class="bg-cozy-card rounded-3xl p-8 max-w-sm w-full text-center shadow-2xl animate-cozy-bounce border border-cozy-warm-gray-light">
        <div class="text-6xl mb-4 animate-cozy-glow">🎉</div>
        <h2 class="text-4xl font-bold text-cozy-accent mb-3">BINGO!</h2>
        <p class="text-cozy-body mb-8 text-lg">You completed a line! 🏆</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-cozy-accent text-white font-bold py-4 px-6 rounded-2xl shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 active:scale-95 border-2 border-cozy-orange-dark text-lg">
            Keep Playing ✨
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}