<div class="flex flex-col min-h-full">
    <!-- Cozy header -->
    <header class="flex items-center justify-between p-4 bg-cozy-card border-b border-cozy-warm-gray-light shadow-sm">
        <button
            @onclick="OnReset"
            class="text-cozy-body text-sm px-4 py-2 rounded-xl hover:bg-cozy-warm transition-colors duration-200 flex items-center gap-2">
            ← Back to Menu
        </button>
        <h1 class="font-bold text-cozy-title text-xl">☕ Soc Ops</h1>
        <div class="w-20"></div> <!-- Spacer -->
    </header>

    <!-- Cozy instructions -->
    <p class="text-center text-cozy-muted text-sm py-3 px-4 bg-cozy-warm/30">
        Tap a square when you find someone who matches it ✨
    </p>

    <!-- Cozy bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-cozy-success/20 text-cozy-brown text-center py-3 font-semibold text-sm border-y border-cozy-success/30 animate-cozy-bounce">
            🎉 BINGO! You got a line! 🎉
        </div>
    }

    <!-- Cozy board container -->
    <div class="flex-1 flex items-center justify-center p-6">
        <div class="bg-cozy-card rounded-3xl p-6 shadow-xl border border-cozy-warm-gray-light">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}